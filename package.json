{
  "name": "@ctrl/irc",
  "version": "0.0.0-placeholder",
  "description": "Node irc client in TypeScript",
  "keywords": [
    "irc",
    "typescript"
  ],
  "license": "MIT",
  "author": "Scott Cooper <scttcper@gmail.com>",
  "repository": "scttcper/irc",
  "files": [
    "dist/src"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/src/index.d.ts",
  "exports": "./dist/src/index.js",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "lint": "oxfmt --check && oxlint .",
    "lint:fix": "oxfmt && oxlint . --fix",
    "prepare": "npm run build",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ci": "vitest run"
  },
  "dependencies": {
    "debug": "^4.4.3",
    "iconv-lite": "^0.7.2",
    "lodash.defaultsdeep": "^4.6.1",
    "tiny-typed-emitter": "^2.1.0"
  },
  "devDependencies": {
    "@ctrl/oxlint-config": "1.5.0",
    "@sindresorhus/tsconfig": "8.1.0",
    "@types/debug": "4.1.13",
    "@types/lodash.defaultsdeep": "4.6.9",
    "@types/node": "25.6.0",
    "oxfmt": "0.47.0",
    "oxlint": "1.62.0",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  },
  "release": {
    "branches": [
      "main"
    ]
  },
  "engines": {
    "node": ">=22"
  }
}
